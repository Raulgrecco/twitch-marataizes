<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Zero Grau — Distribuidora de Bebidas · Barra de Itapemirim · Marataízes ES</title>
<meta name="description" content="Zero Grau Distribuidora de Bebidas em Barra de Itapemirim, Marataízes ES. Melhor preço, bebidas geladas, mesas à noite. Av. Simão Soares, 576. (28) 99978-5411.">
<link rel="canonical" href="https://tvmarataizes.digital/zerograu/">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:ital,wght@0,300;0,400;0,600;0,700;0,900;1,300;1,400;1,700&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">

<style>
/* ═══════════════════════════════════════════
   TOKENS
═══════════════════════════════════════════ */
:root {
  --black:   #040608;
  --dark:    #080C10;
  --dark2:   #0D1318;
  --dark3:   #131B22;
  --ice:     #C8E8F5;
  --ice2:    #E2F4FF;
  --blue:    #1A7FC1;
  --blue2:   #2499E0;
  --blue3:   #4DB8FF;
  --cold:    #0A3D5C;
  --white:   #FFFFFF;
  --muted:   #5A7A8A;
  --zap:     #25D366;
  --gold:    #F0B429;

  --f-hero:  'Bebas Neue', Impact, sans-serif;
  --f-cond:  'Barlow Condensed', sans-serif;
  --f-body:  'Barlow', sans-serif;
  --ease:    cubic-bezier(.16,1,.3,1);
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  background:var(--black);
  color:var(--white);
  font-family:var(--f-body);
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
}
a{text-decoration:none;color:inherit}
img{display:block;max-width:100%}

/* ─── NOISE GRAIN ─── */
body::after{
  content:'';
  position:fixed;inset:0;
  pointer-events:none;
  z-index:9999;
  opacity:.03;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size:200px;
}

/* ─── TOPBAR ─── */
.topbar{
  background:#020507;
  border-bottom:1px solid rgba(26,127,193,.2);
  color:rgba(255,255,255,.4);
  font-family:var(--f-cond);
  font-size:12px;
  font-weight:500;
  letter-spacing:.08em;
  padding:9px 32px;
  display:flex;align-items:center;justify-content:center;
  gap:24px;flex-wrap:wrap;
}
.topbar a{color:var(--blue3);font-weight:700;transition:color .2s}
.topbar a:hover{color:var(--white)}
.t-sep{width:1px;height:11px;background:rgba(255,255,255,.1);flex-shrink:0}

/* ─── HEADER ─── */
.header{
  background:rgba(4,6,8,.95);
  backdrop-filter:blur(16px);
  -webkit-backdrop-filter:blur(16px);
  border-bottom:1px solid rgba(26,127,193,.15);
  padding:0 48px;
  display:flex;align-items:center;justify-content:space-between;
  height:74px;
  position:sticky;top:0;z-index:100;
  transition:height .3s var(--ease);
}
.logo-wrap{display:flex;align-items:center;gap:14px}
.logo-img{
  height:52px;width:auto;
  object-fit:contain;
  filter:drop-shadow(0 0 12px rgba(77,184,255,.4));
}
.logo-text .name{
  font-family:var(--f-hero);
  font-size:28px;
  color:var(--white);
  letter-spacing:.05em;
  line-height:1;
}
.logo-text .sub{
  font-family:var(--f-cond);
  font-size:10px;
  font-weight:600;
  letter-spacing:.25em;
  text-transform:uppercase;
  color:var(--blue3);
  margin-top:2px;
}
.h-nav{display:flex;gap:32px;align-items:center}
.h-nav a{
  font-family:var(--f-cond);
  font-size:12px;font-weight:700;
  letter-spacing:.12em;text-transform:uppercase;
  color:rgba(255,255,255,.4);
  transition:color .2s;
}
.h-nav a:hover{color:var(--white)}
.btn-wpp-h{
  background:var(--zap);
  color:var(--white);
  padding:10px 22px;border-radius:2px;
  font-family:var(--f-cond);
  font-size:13px;font-weight:800;
  letter-spacing:.08em;text-transform:uppercase;
  display:flex;align-items:center;gap:8px;
  transition:all .25s;
  box-shadow:0 4px 20px rgba(37,211,102,.2);
}
.btn-wpp-h:hover{transform:translateY(-1px);box-shadow:0 8px 28px rgba(37,211,102,.35)}

/* ─── HERO ─── */
.hero{
  position:relative;
  min-height:100svh;
  display:flex;
  align-items:flex-end;
  overflow:hidden;
  background:var(--dark);
}

/* Animated ice/cold background */
.hero-bg{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 80% 60% at 70% 40%, rgba(26,127,193,.18) 0%, transparent 70%),
    radial-gradient(ellipse 50% 80% at 20% 80%, rgba(10,61,92,.35) 0%, transparent 60%),
    radial-gradient(ellipse 100% 40% at 50% 0%, rgba(8,12,16,1) 0%, transparent 100%),
    linear-gradient(180deg, #040608 0%, #080C10 40%, #0A1520 100%);
}

/* Ice crystals floating */
.hero-bg::before{
  content:'';
  position:absolute;inset:0;
  background-image:
    radial-gradient(circle 1px at 15% 25%, rgba(77,184,255,.6) 0%, transparent 100%),
    radial-gradient(circle 1px at 35% 60%, rgba(77,184,255,.4) 0%, transparent 100%),
    radial-gradient(circle 2px at 55% 35%, rgba(200,232,245,.5) 0%, transparent 100%),
    radial-gradient(circle 1px at 75% 70%, rgba(77,184,255,.3) 0%, transparent 100%),
    radial-gradient(circle 1px at 88% 20%, rgba(200,232,245,.6) 0%, transparent 100%),
    radial-gradient(circle 2px at 92% 55%, rgba(77,184,255,.4) 0%, transparent 100%),
    radial-gradient(circle 1px at 8% 75%, rgba(200,232,245,.3) 0%, transparent 100%),
    radial-gradient(circle 1px at 48% 85%, rgba(77,184,255,.5) 0%, transparent 100%);
  animation:sparkle 4s ease-in-out infinite alternate;
}
@keyframes sparkle{
  from{opacity:.6}
  to{opacity:1}
}

/* Photo collage right side */
.hero-photos{
  position:absolute;
  right:0;top:0;bottom:0;
  width:52%;
  display:grid;
  grid-template-columns:1fr 1fr;
  grid-template-rows:1fr 1fr;
  gap:3px;
  overflow:hidden;
}
.hero-photos::before{
  content:'';
  position:absolute;
  left:0;top:0;bottom:0;width:200px;
  background:linear-gradient(to right,var(--dark) 0%,transparent 100%);
  z-index:2;
}
.hero-photos::after{
  content:'';
  position:absolute;
  inset:0;
  background:linear-gradient(to top,var(--dark) 0%,rgba(4,6,8,.2) 40%,transparent 100%);
  z-index:2;
}
.hp{overflow:hidden;background:var(--dark3)}
.hp img{
  width:100%;height:100%;
  object-fit:cover;
  filter:saturate(.7) brightness(.75);
  transition:transform .7s var(--ease),filter .5s;
  display:block;
}
.hp:hover img{transform:scale(1.06);filter:saturate(.9) brightness(.9)}
.hp.tall{grid-row:span 2}

/* Hero content */
.hero-content{
  position:relative;z-index:3;
  padding:0 64px 80px;
  max-width:700px;
}

.hero-badge{
  display:inline-flex;align-items:center;gap:10px;
  font-family:var(--f-cond);
  font-size:10px;font-weight:700;
  letter-spacing:.28em;text-transform:uppercase;
  color:var(--blue3);
  border:1px solid rgba(77,184,255,.3);
  padding:8px 18px;border-radius:1px;
  margin-bottom:24px;
  opacity:0;animation:fadeUp .8s var(--ease) .2s forwards;
}
.badge-dot{
  width:6px;height:6px;
  background:var(--blue3);border-radius:50%;
  animation:pulse-dot 1.8s ease-in-out infinite;
}
@keyframes pulse-dot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.3;transform:scale(.7)}}

.hero h1{
  font-family:var(--f-hero);
  font-size:clamp(64px,10vw,130px);
  color:var(--white);
  line-height:.92;
  letter-spacing:.02em;
  margin-bottom:4px;
  opacity:0;animation:fadeUp .9s var(--ease) .38s forwards;
}
.hero h1 .cold-word{
  display:block;
  background:linear-gradient(135deg,var(--blue3),var(--ice2));
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
}
.hero h1 .sub-word{
  display:block;
  font-size:clamp(28px,4.5vw,58px);
  font-family:var(--f-cond);
  font-weight:300;
  letter-spacing:.2em;
  color:rgba(255,255,255,.5);
  -webkit-text-fill-color:rgba(255,255,255,.5);
  background:none;
  margin-top:8px;
}

.hero-temp{
  display:inline-flex;align-items:baseline;gap:4px;
  font-family:var(--f-hero);
  font-size:clamp(80px,12vw,160px);
  color:var(--blue3);
  line-height:1;
  opacity:.08;
  position:absolute;
  right:54%;bottom:60px;
  letter-spacing:-.02em;
  pointer-events:none;
  user-select:none;
}

.hero-desc{
  font-size:16px;
  color:rgba(255,255,255,.45);
  line-height:1.85;
  font-weight:300;
  max-width:460px;
  margin:24px 0 38px;
  opacity:0;animation:fadeUp .9s var(--ease) .54s forwards;
}
.hero-desc strong{color:rgba(255,255,255,.8);font-weight:500}

/* Pills */
.hero-pills{
  display:flex;gap:8px;flex-wrap:wrap;
  margin-bottom:36px;
  opacity:0;animation:fadeUp .9s var(--ease) .66s forwards;
}
.pill{
  display:inline-flex;align-items:center;gap:6px;
  background:rgba(26,127,193,.12);
  border:1px solid rgba(77,184,255,.2);
  color:var(--blue3);
  font-family:var(--f-cond);
  font-size:12px;font-weight:700;
  padding:7px 14px;border-radius:100px;
  letter-spacing:.06em;
  transition:background .2s;
}
.pill:hover{background:rgba(26,127,193,.22)}

/* Buttons */
.hero-btns{
  display:flex;gap:12px;flex-wrap:wrap;
  opacity:0;animation:fadeUp .9s var(--ease) .78s forwards;
}
.btn-primary{
  background:var(--zap);
  color:var(--white);
  padding:16px 32px;border-radius:2px;
  font-family:var(--f-cond);
  font-size:14px;font-weight:800;
  letter-spacing:.1em;text-transform:uppercase;
  display:flex;align-items:center;gap:10px;
  transition:all .25s;
  box-shadow:0 6px 32px rgba(37,211,102,.25);
}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 10px 40px rgba(37,211,102,.4)}
.btn-ghost{
  border:1px solid rgba(77,184,255,.25);
  color:rgba(255,255,255,.6);
  padding:16px 26px;border-radius:2px;
  font-family:var(--f-cond);
  font-size:13px;font-weight:600;
  letter-spacing:.07em;
  display:flex;align-items:center;gap:8px;
  transition:all .25s;
}
.btn-ghost:hover{border-color:rgba(77,184,255,.6);color:var(--white)}

/* Stats */
.hero-stats{
  position:absolute;bottom:0;right:0;
  display:flex;
  background:rgba(8,12,16,.95);
  border-top:1px solid rgba(26,127,193,.15);
  border-left:1px solid rgba(26,127,193,.15);
  z-index:4;
}
.hstat{
  padding:20px 28px;
  border-right:1px solid rgba(255,255,255,.06);
  text-align:center;
}
.hstat:last-child{border-right:none}
.hstat-n{
  font-family:var(--f-hero);
  font-size:32px;
  background:linear-gradient(135deg,var(--blue2),var(--blue3));
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
  display:block;line-height:1;
}
.hstat-l{
  font-family:var(--f-cond);
  font-size:9px;font-weight:700;
  letter-spacing:.18em;text-transform:uppercase;
  color:rgba(255,255,255,.28);
  display:block;margin-top:4px;
}

/* ─── MARQUEE ─── */
.marquee{
  background:linear-gradient(135deg,var(--blue),var(--blue2));
  overflow:hidden;padding:13px 0;white-space:nowrap;
}
.mq-track{display:inline-flex;animation:mq 20s linear infinite}
.mq-item{
  font-family:var(--f-cond);
  font-size:12px;font-weight:800;
  letter-spacing:.18em;text-transform:uppercase;
  color:var(--white);
  padding:0 28px;
  display:inline-flex;align-items:center;gap:10px;
}
.mq-item::after{content:'❄';opacity:.5;font-size:10px}
@keyframes mq{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ─── DIFERENCIAIS ─── */
.dif-sec{background:var(--dark2);position:relative;overflow:hidden}
.dif-sec::before{
  content:'';position:absolute;
  top:-200px;right:-100px;
  width:600px;height:600px;
  background:radial-gradient(ellipse,rgba(26,127,193,.06) 0%,transparent 70%);
  pointer-events:none;
}
.dif-inner{
  max-width:1280px;margin:0 auto;
  padding:80px 64px;
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:2px;
}
.dif-card{
  background:rgba(255,255,255,.02);
  border:1px solid rgba(255,255,255,.05);
  padding:36px 28px;
  transition:background .3s,border-color .3s;
  position:relative;overflow:hidden;
}
.dif-card::after{
  content:'';
  position:absolute;
  top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--blue),var(--blue3));
  transform:scaleX(0);transform-origin:left;
  transition:transform .4s var(--ease);
}
.dif-card:hover{background:rgba(26,127,193,.06);border-color:rgba(77,184,255,.15)}
.dif-card:hover::after{transform:scaleX(1)}
.dif-ico{
  font-size:32px;
  width:56px;height:56px;
  background:rgba(26,127,193,.1);
  border:1px solid rgba(77,184,255,.15);
  border-radius:2px;
  display:flex;align-items:center;justify-content:center;
  margin-bottom:18px;
  flex-shrink:0;
}
.dif-title{
  font-family:var(--f-cond);
  font-size:16px;font-weight:800;
  color:var(--white);
  letter-spacing:.04em;
  margin-bottom:8px;
  text-transform:uppercase;
}
.dif-desc{
  font-size:13px;
  color:rgba(255,255,255,.38);
  line-height:1.75;font-weight:300;
}

/* ─── GALERIA ─── */
.gal-sec{background:var(--dark);position:relative}
.gal-sec::before{
  content:'';position:absolute;
  top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--blue2),transparent);
}
.gal-head{
  max-width:1280px;margin:0 auto;
  padding:80px 64px 40px;
  display:flex;align-items:flex-end;justify-content:space-between;
  gap:32px;flex-wrap:wrap;
}
.sec-label{
  display:block;
  font-family:var(--f-cond);
  font-size:10px;font-weight:700;
  letter-spacing:.28em;text-transform:uppercase;
  color:var(--blue3);margin-bottom:10px;
}
.sec-title{
  font-family:var(--f-hero);
  font-size:clamp(36px,5vw,64px);
  color:var(--white);
  line-height:1;letter-spacing:.02em;
}
.sec-title em{
  font-style:italic;
  font-family:var(--f-cond);
  font-weight:300;
  color:var(--blue3);
  font-size:.75em;
  letter-spacing:.1em;
}

.gal-grid{
  display:grid;
  grid-template-columns:1.5fr 1fr 1fr;
  grid-template-rows:280px 280px;
  gap:3px;
}
.gal{overflow:hidden;position:relative;background:var(--dark3);cursor:zoom-in}
.gal img{
  width:100%;height:100%;
  object-fit:cover;
  transition:transform .7s var(--ease),filter .5s;
  display:block;
  filter:saturate(.8) brightness(.85);
}
.gal:hover img{transform:scale(1.08);filter:saturate(1) brightness(1)}
.gal.tall{grid-row:span 2}
.gal-ov{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(4,6,8,.8) 0%,transparent 55%);
  opacity:0;transition:opacity .4s;
}
.gal:hover .gal-ov{opacity:1}
.gal-cap{
  position:absolute;bottom:18px;left:20px;
  opacity:0;transform:translateY(8px);
  transition:all .4s var(--ease);
}
.gal:hover .gal-cap{opacity:1;transform:translateY(0)}
.gal-cap span{
  font-family:var(--f-cond);
  font-size:11px;font-weight:700;
  letter-spacing:.14em;text-transform:uppercase;
  color:var(--blue3);
}

/* ─── NOITE — destaque especial ─── */
.noite-sec{
  background:var(--dark2);
  position:relative;overflow:hidden;
}
.noite-sec::before{
  content:'';position:absolute;
  bottom:-100px;left:50%;
  transform:translateX(-50%);
  width:800px;height:400px;
  background:radial-gradient(ellipse,rgba(26,127,193,.1) 0%,transparent 70%);
  pointer-events:none;
}
.noite-inner{
  max-width:1280px;margin:0 auto;
  padding:100px 64px;
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:80px;align-items:center;
}
.noite-text{}
.noite-kicker{
  display:inline-flex;align-items:center;gap:8px;
  font-family:var(--f-cond);
  font-size:10px;font-weight:700;
  letter-spacing:.26em;text-transform:uppercase;
  color:var(--gold);
  border:1px solid rgba(240,180,41,.25);
  padding:7px 16px;border-radius:1px;
  margin-bottom:24px;
}
.noite-title{
  font-family:var(--f-hero);
  font-size:clamp(48px,6vw,80px);
  color:var(--white);
  line-height:.95;
  letter-spacing:.02em;
  margin-bottom:24px;
}
.noite-title span{
  display:block;
  background:linear-gradient(135deg,var(--gold),#FFD066);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
}
.noite-desc{
  font-size:15px;
  color:rgba(255,255,255,.42);
  line-height:1.9;font-weight:300;
  margin-bottom:32px;
}
.noite-feats{
  display:flex;flex-direction:column;gap:12px;
  margin-bottom:40px;
}
.noite-feat{
  display:flex;align-items:center;gap:14px;
  padding:14px 18px;
  background:rgba(240,180,41,.05);
  border:1px solid rgba(240,180,41,.12);
  border-left:2px solid var(--gold);
  transition:background .25s;
}
.noite-feat:hover{background:rgba(240,180,41,.1)}
.nf-ico{font-size:20px;flex-shrink:0}
.nf-title{font-family:var(--f-cond);font-size:13px;font-weight:800;color:var(--white);margin-bottom:2px;text-transform:uppercase;letter-spacing:.04em}
.nf-desc{font-size:12px;color:rgba(255,255,255,.35);line-height:1.5}

/* Noite visual */
.noite-visual{position:relative}
.noite-img-frame{
  position:relative;
  border:1px solid rgba(240,180,41,.2);
}
.noite-img{
  width:100%;height:480px;
  object-fit:cover;
  display:block;
  filter:saturate(.7) brightness(.7);
}
.noite-glow{
  position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(240,180,41,.08) 0%,transparent 60%);
  pointer-events:none;
}
/* Gold corners */
.nc{position:absolute;width:24px;height:24px;pointer-events:none}
.nc.tl{top:-1px;left:-1px;border-top:2px solid var(--gold);border-left:2px solid var(--gold)}
.nc.tr{top:-1px;right:-1px;border-top:2px solid var(--gold);border-right:2px solid var(--gold)}
.nc.bl{bottom:-1px;left:-1px;border-bottom:2px solid var(--gold);border-left:2px solid var(--gold)}
.nc.br{bottom:-1px;right:-1px;border-bottom:2px solid var(--gold);border-right:2px solid var(--gold)}
.noite-badge{
  position:absolute;
  bottom:-20px;right:-20px;
  background:linear-gradient(135deg,var(--gold),#FFD066);
  color:#1A0A00;
  padding:18px 22px;
  text-align:center;
  box-shadow:0 8px 32px rgba(240,180,41,.3);
  z-index:2;
}
.noite-badge-n{
  font-family:var(--f-hero);
  font-size:38px;line-height:1;
  display:block;
}
.noite-badge-t{
  font-family:var(--f-cond);
  font-size:9px;font-weight:800;
  letter-spacing:.16em;text-transform:uppercase;
  display:block;margin-top:2px;opacity:.8;
}

/* ─── CONTATO ─── */
.ct-sec{background:var(--black)}
.ct-sec::before{
  content:'';display:block;height:1px;
  background:linear-gradient(90deg,transparent,var(--blue2),transparent);
}
.ct-inner{
  max-width:1280px;margin:0 auto;
  padding:88px 64px;
  display:grid;
  grid-template-columns:1fr 380px;
  gap:72px;align-items:start;
}
.info-cards{display:flex;flex-direction:column;gap:2px;margin-top:40px}
.ic{
  background:rgba(255,255,255,.02);
  border:1px solid rgba(255,255,255,.06);
  padding:22px 26px;
