<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rede Sul Capixaba de Comunicação</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ink: #0a0a0a;
    --ink-mid: #3a3a3a;
    --ink-light: #7a7a7a;
    --rule: #e0ddd8;
    --bg: #faf9f7;
    --bg-alt: #f2f0ec;
    --accent: #1a1a1a;
    --serif: 'Playfair Display', Georgia, serif;
    --sans: 'DM Sans', system-ui, sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--sans);
    background: var(--bg);
    color: var(--ink);
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.25rem 3rem;
    background: rgba(250,249,247,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--rule);
  }
  .nav-brand {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--ink);
    text-decoration: none;
  }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-light);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--ink); }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 0 3rem 5rem;
    position: relative;
    border-bottom: 1px solid var(--rule);
  }
  .hero-bg {
    position: absolute; inset: 0;
    background: linear-gradient(160deg, #0a0a0a 0%, #1c1c1c 60%, #2a2a2a 100%);
    z-index: 0;
  }
  .hero-grid {
    position: absolute; inset: 0; z-index: 1;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .hero-content { position: relative; z-index: 2; max-width: 900px; }
  .hero-eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-bottom: 1.5rem;
    display: flex; align-items: center; gap: 1rem;
  }
  .hero-eyebrow::before {
    content: '';
    display: block; width: 32px; height: 1px;
    background: rgba(255,255,255,0.3);
  }
  .hero-title {
    font-family: var(--serif);
    font-size: clamp(2.8rem, 6vw, 5.5rem);
    font-weight: 400;
    line-height: 1.08;
    color: #fff;
    margin-bottom: 2rem;
    letter-spacing: -0.01em;
  }
  .hero-title em { font-style: italic; color: rgba(255,255,255,0.6); }
  .hero-sub {
    font-size: 1rem;
    font-weight: 300;
    color: rgba(255,255,255,0.55);
    max-width: 520px;
    line-height: 1.7;
    margin-bottom: 3rem;
  }
  .hero-meta {
    display: flex; gap: 3rem; flex-wrap: wrap;
  }
  .hero-meta-item { }
  .hero-meta-item .val {
    font-family: var(--serif);
    font-size: 2rem;
    font-weight: 400;
    color: #fff;
    display: block;
    line-height: 1;
    margin-bottom: 4px;
  }
  .hero-meta-item .lbl {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
  }

  /* SECTIONS */
  section { padding: 6rem 3rem; border-bottom: 1px solid var(--rule); }
  .section-header {
    display: flex; align-items: baseline; gap: 1.5rem;
    margin-bottom: 3.5rem;
  }
  .section-num {
    font-family: var(--serif);
    font-size: 0.85rem;
    color: var(--ink-light);
    font-style: italic;
  }
  .section-title {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-light);
  }

  /* IMPACTO */
  .impact-intro {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    font-weight: 400;
    line-height: 1.4;
    max-width: 700px;
    margin-bottom: 3rem;
    color: var(--ink);
  }
  .cases { display: flex; flex-direction: column; gap: 0; }
  .case {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 0 2rem;
    padding: 2rem 0;
    border-top: 1px solid var(--rule);
    align-items: start;
  }
  .case:last-child { border-bottom: 1px solid var(--rule); }
  .case-num {
    font-family: var(--serif);
    font-size: 0.85rem;
    color: var(--ink-light);
    font-style: italic;
    padding-top: 3px;
  }
  .case-body { }
  .case-title {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: var(--ink);
  }
  .case-text {
    font-size: 0.9rem;
    color: var(--ink-mid);
    line-height: 1.65;
    margin-bottom: 0.65rem;
    max-width: 640px;
  }
  .case-result {
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--ink);
    font-weight: 500;
    display: flex; align-items: center; gap: 0.5rem;
  }
  .case-result::before {
    content: '';
    display: inline-block;
    width: 18px; height: 1px;
    background: var(--ink);
  }

  /* ALCANCE */
  .reach-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
    margin-bottom: 3rem;
  }
  .reach-item {
    background: var(--bg);
    padding: 2rem 1.5rem;
  }
  .reach-val {
    font-family: var(--serif);
    font-size: 2.4rem;
    font-weight: 400;
    color: var(--ink);
    display: block;
    line-height: 1;
    margin-bottom: 6px;
  }
  .reach-lbl {
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-light);
  }
  .reach-note {
    font-size: 0.85rem;
    color: var(--ink-light);
    line-height: 1.65;
    max-width: 500px;
    font-style: italic;
  }

  /* MUNICIPIOS */
  .muni-wrap {
    display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 2rem;
  }
  .muni {
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    border: 1px solid var(--rule);
    padding: 6px 14px;
    color: var(--ink-mid);
    background: transparent;
  }
  .muni.plus { color: var(--ink-light); border-style: dashed; }

  /* ESTRUTURA */
  .structure-list { display: flex; flex-direction: column; gap: 0; }
  .struct-item {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--rule);
    align-items: start;
  }
  .struct-item:last-child { border-bottom: 1px solid var(--rule); }
  .struct-label {
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-light);
    padding-top: 2px;
  }
  .struct-value {
    font-size: 0.92rem;
    color: var(--ink-mid);
    line-height: 1.55;
  }
  .struct-value strong { color: var(--ink); font-weight: 500; }

  /* DIRETOR */
  .director-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .director-statement {
    font-family: var(--serif);
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    font-weight: 400;
    line-height: 1.45;
    color: var(--ink);
  }
  .director-statement em { font-style: italic; color: var(--ink-mid); }
  .director-creds { display: flex; flex-direction: column; gap: 0; }
  .cred-row {
    padding: 0.85rem 0;
    border-top: 1px solid var(--rule);
    font-size: 0.88rem;
    color: var(--ink-mid);
    line-height: 1.5;
  }
  .cred-row:last-child { border-bottom: 1px solid var(--rule); }
  .cred-row strong { color: var(--ink); font-weight: 500; display: block; font-size: 0.8rem; letter-spacing: 0.04em; text-transform: uppercase; margin-bottom: 2px; }

  /* PROPOSTA */
  .proposta-bg {
    background: var(--ink);
    color: #fff;
    border-bottom: none;
  }
  .proposta-bg .section-title { color: rgba(255,255,255,0.35); }
  .proposta-bg .section-num { color: rgba(255,255,255,0.25); }
  .proposta-statement {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 3vw, 2.4rem);
    font-weight: 400;
    line-height: 1.3;
    max-width: 760px;
    margin-bottom: 3rem;
    color: #fff;
  }
  .proposta-statement em { color: rgba(255,255,255,0.5); font-style: italic; }
  .proposta-items {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 3rem;
  }
  .proposta-item {
    background: var(--ink);
    padding: 1.75rem;
  }
  .proposta-item-title {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 0.75rem;
  }
  .proposta-item-text {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.55;
  }
  .proposta-note {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.4);
    line-height: 1.65;
    max-width: 560px;
    border-left: 1px solid rgba(255,255,255,0.15);
    padding-left: 1.25rem;
  }

  /* FOOTER */
  footer {
    padding: 3rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1.5rem;
    background: var(--bg);
  }
  .footer-brand {
    font-family: var(--serif);
    font-size: 1.1rem;
    color: var(--ink);
    margin-bottom: 0.4rem;
  }
  .footer-detail {
    font-size: 0.78rem;
    color: var(--ink-light);
    line-height: 1.7;
  }
  .footer-contact { text-align: right; }
  .footer-contact a {
    display: block;
    font-size: 0.82rem;
    color: var(--ink-mid);
    text-decoration: none;
    line-height: 1.8;
  }
  .footer-contact a:hover { color: var(--ink); }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-eyebrow { animation: fadeUp 0.7s ease both; }
  .hero-title { animation: fadeUp 0.7s 0.15s ease both; }
  .hero-sub { animation: fadeUp 0.7s 0.25s ease both; }
  .hero-meta { animation: fadeUp 0.7s 0.35s ease both; }

  @media (max-width: 768px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { display: none; }
    .hero { padding: 0 1.5rem 4rem; }
    section { padding: 4rem 1.5rem; }
    .director-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .struct-item { grid-template-columns: 1fr; gap: 0.5rem; }
    .struct-label { padding-top: 0; }
    footer { padding: 2rem 1.5rem; }
    .footer-contact { text-align: left; }
  }
</style>
</head>
