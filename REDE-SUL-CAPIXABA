        DVD Rosemary em "Mulheres da Mangueira" — participações de Beth Carvalho, Chico Buarque, Zeca Pagodinho e Alcione · Patrocínio Petrobras
      </div>
    </div>
  </div>
</section>

<!-- PROPOSTA -->
<section id="proposta" class="proposta-bg">
  <div class="section-header">
    <span class="section-num">05</span>
    <span class="section-title">Proposta</span>
